# Bluesky credentials (for publishing the feed generator record)
BSKY_SERVICE=https://bsky.social
BSKY_IDENTIFIER=your-handle.bsky.social
BSKY_PASSWORD=your-app-password

# Feed generator configuration
FEED_HOSTNAME=my-feed.example.com
FEED_RKEY=my-cool-feed
FEED_DISPLAY_NAME=My Cool Feed
FEED_DESCRIPTION=A custom feed that filters posts by keyword

# Algorithm configuration
FEED_KEYWORD=#VTuber

# Like aggregation: comma-separated list of DIDs whose likes to index
# Leave empty to only use keyword filtering
TARGET_DIDS=

# Server port
PORT=3000
