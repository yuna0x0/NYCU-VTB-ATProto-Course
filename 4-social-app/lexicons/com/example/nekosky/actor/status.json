{
  "lexicon": 1,
  "id": "com.example.nekosky.actor.status",
  "defs": {
    "main": {
      "type": "record",
      "description": "A personal status message displayed on the user's profile.",
      "key": "self",
      "record": {
        "type": "object",
        "required": ["text", "createdAt"],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100,
            "description": "The status text."
          },
          "emoji": {
            "type": "string",
            "maxLength": 10,
            "description": "An optional emoji to display with the status."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime",
            "description": "Timestamp of when the status was set."
          }
        }
      }
    }
  }
}
