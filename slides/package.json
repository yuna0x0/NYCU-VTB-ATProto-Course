{
  "name": "slides",
  "type": "module",
  "scripts": {
    "dev": "slidev course1.md --open",
    "dev:1": "slidev course1.md --open",
    "build": "node scripts/build.mjs",
    "build:1": "slidev build course1.md",
    "export": "slidev export course1.md",
    "export:1": "slidev export course1.md",
    "dev:2": "slidev course2.md --open",
    "build:2": "slidev build course2.md --base /course2/ --out dist/course2",
    "export:2": "slidev export course2.md",
    "dev:3": "slidev course3.md --open",
    "build:3": "slidev build course3.md --base /course3/ --out dist/course3",
    "export:3": "slidev export course3.md"
  },
  "dependencies": {
    "@slidev/cli": "^52.14.1",
    "@slidev/theme-default": "latest",
    "@slidev/theme-seriph": "latest",
    "sakana-widget": "^2.7.1",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.97",
    "playwright-chromium": "^1.58.2"
  }
}
