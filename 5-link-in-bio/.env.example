# Development — leave unset to use the built-in loopback dev default (127.0.0.1:5175).
# Only set these if you need non-default dev URLs (e.g. HTTPS tunnel, different port).
# VITE_OAUTH_CLIENT_ID=
# VITE_OAUTH_REDIRECT_URI=

# Production — replace with your deployed URLs before `pnpm build`.
# The client_id URL MUST be the public URL where oauth-client-metadata.json is served.
# VITE_OAUTH_CLIENT_ID=https://your-app.example.com/oauth-client-metadata.json
# VITE_OAUTH_REDIRECT_URI=https://your-app.example.com/callback
